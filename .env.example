# Copiar a .env o exportar variables.

POSTGRES_USER=parking
POSTGRES_PASSWORD=parking_dev
POSTGRES_DB=parking
DATABASE_URL=postgresql://parking:parking_dev@localhost:5432/parking

BACKEND_PUBLIC_URL=http://localhost:8000
FRONTEND_PUBLIC_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=

MOCK_PAYMENTS=true

DEVICE_HMAC_SECRET=dev_cambiar_en_produccion_minimo_32_chars_xx
# ESP32 barrera de salida (mismo DEVICE_ID que en firmware de salida)
DEFAULT_GATE_DEVICE_ID=gate-01
# ESP32 barrera de ingreso (otro dispositivo, o el mismo id solo en pruebas con un solo ESP32)
ENTRY_GATE_DEVICE_ID=gate-entry-01
SESSION_SIGNING_SECRET=dev_session_signing_secret_cambiar

# Tarifa: centavos ARS por minuto (redondeo hacia arriba), mínimo y segundos de gracia opcional
PARKING_PRICE_PER_MINUTE_CENTS=50
PARKING_MINIMUM_CENTS=100
PARKING_GRACE_SECONDS=0
